{
  "name": "phore/orm",
  "description": "Object Relational Mapper",
  "license": "MIT",
  "authors": [
    { "name": "Matthias Leuffen", "email": "m@tth.es" }
  ],
  "require": {
    "php": ">=8.1"

  },

  "suggest": {
  },
  "autoload": {
    "psr-4": {
        "Phore\\MiniSql\\": "src/",
        "Phore\\MiniSql\\Test\\": "test/"
    }
  },
  "minimum-stability": "dev",
  "require-dev": {
      "brixlab/coder": "dev-main",
      "pestphp/pest": "^3.7"
  },
  "scripts": {
    "test": "vendor/bin/pest"
  },
  "config": {
    "preferred-install": "source",
    "allow-plugins": {
      "php-http/discovery": false,
      "pestphp/pest-plugin": true
    }
  }
}
